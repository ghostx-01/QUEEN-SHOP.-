<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Business</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
    }

    header {
      background: #020617;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    header h1 {
      color: #38bdf8;
    }

    nav a {
      color: white;
      margin-left: 20px;
      text-decoration: none;
    }

    nav a:hover {
      color: #38bdf8;
    }

    .hero {
      text-align: center;
      padding: 100px 20px;
      background: linear-gradient(to right, #0ea5e9, #22c55e);
    }

    .hero h2 {
      font-size: 40px;
    }

    .hero button {
      padding: 12px 25px;
      border: none;
      background: black;
      color: white;
      cursor: pointer;
      margin-top: 20px;
    }

    .services {
      padding: 50px 20px;
      text-align: center;
    }

    .services h2 {
      margin-bottom: 30px;
    }

    .service-box {
      display: inline-block;
      width: 250px;
      margin: 10px;
      padding: 20px;
      background: #1e293b;
      border-radius: 10px;
    }

    .contact {
      padding: 50px;
      text-align: center;
      background: #020617;
    }

    input, textarea {
      width: 80%;
      padding: 10px;
      margin: 10px;
      border: none;
      border-radius: 5px;
    }

    button.send {
      background: #22c55e;
      color: white;
      padding: 10px 20px;
      border: none;
      cursor: pointer;
    }

    footer {
      text-align: center;
      padding: 15px;
      background: black;
    }
  </style>
</head>

<body>

<header>
  <h1>My Business</h1>
  <nav>
    <a href="#">Home</a>
    <a href="#services">Services</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<section class="hero">
  <h2>Welcome to My Business</h2>
  <p>We provide the best services for you</p>
  <button onclick="alert('Contact us below!')">Get Started</button>
</section>

<section class="services" id="services">
  <h2>Our Services</h2>

  <div class="service-box">
    <h3>Web Design</h3>
    <p>Modern and responsive websites</p>
  </div>

  <div class="service-box">
    <h3>Marketing</h3>
    <p>Grow your business online</p>
  </div>

  <div class="service-box">
    <h3>Support</h3>
    <p>24/7 customer support</p>
  </div>
</section>

<section class="contact" id="contact">
  <h2>Contact Us</h2>

  <input type="text" placeholder="Your Name"><br>
  <input type="email" placeholder="Your Email"><br>
  <textarea placeholder="Your Message"></textarea><br>

  <button class="send" onclick="sendMessage()">Send</button>
</section>

<footer>
  <p>© 2026 My Business. All rights reserved.</p>
</footer>

<script>
  function sendMessage() {
    alert("Message sent successfully!");
  }
</script>

</body>
</html>
